@startuml SD_01_Login

skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBackgroundColor #D6EAF8
skinparam sequenceParticipantBorderColor #1E88E5
skinparam sequenceLifeLineBorderColor #1E88E5
skinparam sequenceMessageAlign left
skinparam sequenceGroupBorderColor #E74C3C
skinparam sequenceGroupFontSize 11
skinparam noteFontSize 11
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825
skinparam actorBackgroundColor #FDEBD0
skinparam databaseBackgroundColor #D5F5E3
skinparam databaseBorderColor #1E8449

title 1. Login

actor       "User"                                    as User
participant "Login Page\n(app/login/page.tsx)"        as LoginPage
participant "Server Actions\n(app/login/actions.ts)"  as Actions
participant "Supabase Auth\n(supabase.auth)"           as Auth
database    "Database\n(Supabase PostgreSQL)"          as DB

User -> LoginPage      : nhập email / password
LoginPage -> LoginPage : handleEmailSubmit(formData)
LoginPage -> Actions   : signInWithEmail(formData)
activate Actions
Actions -> Auth        : auth.signInWithPassword\n({ email, password })
activate Auth
Auth -> DB             : SELECT * FROM auth.users\nWHERE email = $email
DB --> Auth            : user record
Auth --> Actions       : { data: { user, session } } | { error }
deactivate Auth

alt Login thất bại
  Actions --> LoginPage : return { error: error.message }
  LoginPage --> User    : hiển thị thông báo lỗi
else Login thành công
  Actions -> Actions    : getRedirectByRole()
  Actions -> Auth       : auth.getUser()
  Auth --> Actions      : user.id
  Actions -> DB         : SELECT role_id FROM profiles\nWHERE user_id = $userId
  DB --> Actions        : { role_id }
  note right of Actions : role_id=1 → /admin\nrole_id=2 → /seller\ndefault → /
  Actions --> LoginPage : redirect(dest)
  deactivate Actions
  LoginPage --> User    : chuyển hướng đến dashboard
end

@enduml
